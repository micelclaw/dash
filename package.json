{
  "name": "@micelclaw/dash",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "description": "Claw Dash — Micelclaw frontend (Phase 9)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && NODE_OPTIONS='--max-old-space-size=4096' vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "e2e": "cd tests && playwright test",
    "e2e:ui": "cd tests && playwright test --ui",
    "e2e:headed": "cd tests && playwright test --headed",
    "e2e:flows": "cd tests && playwright test e2e/flows.spec.ts && npx tsx e2e/generate-report.ts",
    "e2e:flows:headed": "cd tests && playwright test e2e/flows.spec.ts --headed && npx tsx e2e/generate-report.ts",
    "e2e:auth:save": "cd tests && tsx mcp/auth/save-paco-storage.ts",
    "contracts": "cd tests && playwright test --config playwright.contracts.config.ts",
    "contracts:headed": "cd tests && playwright test --config playwright.contracts.config.ts --headed"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
